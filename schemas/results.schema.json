{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "redis-stig-audit results",
  "type": "object",
  "required": ["target", "results"],
  "properties": {
    "target": {
      "type": "object"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "title", "status", "severity"],
        "properties": {
          "check_id": {"type": "string"},
          "benchmark_control_id": {"type": ["string", "null"]},
          "title": {"type": "string"},
          "status": {"type": "string"},
          "severity": {"type": "string"},
          "category": {"type": "string"},
          "description": {"type": "string"},
          "actual": {"type": "string"},
          "expected": {"type": "string"},
          "remediation": {"type": "string"},
          "references": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
